{
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs": 60000,
        "lockoutMs": 300000
      }
    },
    "mode": "local",
    "bind": "loopback",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:${OPENCLAW_GATEWAY_PORT}",
        "http://localhost:${OPENCLAW_GATEWAY_PORT}"
      ]
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.31"
  },
  "agents": {
    "defaults": {
      "workspace": "${OPENCLAW_WORKSPACE}",
      "heartbeat": {
        "every": "0m"
      },
      "model": {
        "primary": "${OPENCLAW_MODEL_PRIMARY}"
      }
    }
  },
  "models": {
    "providers": {
      "openai": {
        "baseUrl": "${OPENAI_BASE_URL}",
        "models": []
      }
    }
  },
  "plugins": {
    "entries": {
      "qqbot": {
        "enabled": true
      }
    }
  },
  "channels": {
    "qqbot": {
      "enabled": true,
      "allowFrom": [
        "*"
      ],
      "systemPrompt": "你是 QQ Bot 专属机器人“小龙虾”。默认中文，简洁直接，先给结论。默认关注 3ms 工作区。处理 3ms 请求时，优先使用 $3ms-workspace-ops。若用户发送的是精确固定口令或固定模板，直接把用户原句原样传给 qq-3ms-intent，让脚本自己解析；不要自己把短口令翻译成数字 intent。对于切分支模板，也传完整原句，例如 切分支 v0.0.3。若不是精确口令，先给候选短口令确认。当前只保留 10 条动作口令：看上游更新、同步更新、拉取上游仓库并部署、拉取主项目、拉取主项目并部署、看分支、列分支、切分支 <branch>、部署前检查、执行部署；帮助口令只有 口令 和 列出所有口令。历史长句不再直接执行。必须严格区分 upstream 和 origin，不要猜。脚本输出 QQ_RESULT= 或 QQ_DETAIL= 时直接复用。遇到 merge 冲突、Git 身份缺失、commit/push 失败、网络或鉴权错误时，直接说明失败点和关键原因。若遇到审批或 exec deny，不要暴露内部审批细节，只回复业务化提示。",
      "appId": "${QQBOT_APP_ID}",
      "clientSecret": "${QQBOT_CLIENT_SECRET}"
    }
  }
}

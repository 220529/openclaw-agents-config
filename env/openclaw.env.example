# Copy to ~/.config/openclaw/openclaw.env and fill required values.

# Base directories
OPENCLAW_STATE_DIR="${HOME}/.openclaw"
OPENCLAW_WORKSPACE="${OPENCLAW_STATE_DIR}/workspace"
CODEX_HOME="${HOME}/.codex"

# 3ms workspace
THREEMS_WORKSPACE="/root/3ms"
THREEMS_MAIN_REPO="${THREEMS_WORKSPACE}/sub2api-main"
THREEMS_BACKEND_REPO="${THREEMS_WORKSPACE}/3ms_backend"
THREEMS_FRONTEND_REPO="${THREEMS_WORKSPACE}/3ms_frontend"

# Gateway runtime
OPENCLAW_GATEWAY_PORT="18789"
OPENCLAW_GATEWAY_TOKEN=""
OPENCLAW_MODEL_PRIMARY="openai/gpt-5.4"
OPENAI_BASE_URL=""
OPENCLAW_NODE_BIN=""
OPENCLAW_NODE_MODULES_DIR=""

# QQ bot channel
QQBOT_APP_ID=""
QQBOT_CLIENT_SECRET=""
QQBOT_SECONDARY_ENABLED=false
QQBOT_SECONDARY_APP_ID=""
QQBOT_SECONDARY_CLIENT_SECRET=""

# Optional: override if global npm root is non-standard for the current machine.
# OPENCLAW_NODE_MODULES_DIR=""
